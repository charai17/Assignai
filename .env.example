# AssignAI direct backend
# OpenAI is preferred when OPENAI_API_KEY is set. Leave AI keys blank to use the built-in mock fallback while testing the UI.
AI_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Optional OpenRouter fallback.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Supabase auth and saved history.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional OpenRouter attribution headers.
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=AssignAI

# Optional runtime tuning.
SERVICE_NAME=assignai
AI_REQUEST_TIMEOUT_MS=45000
MAX_INPUT_CHARS=20000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
