# n8n webhooks. Leave blank for mock mode.
# Use /webhook/... production URLs for active n8n workflows; /webhook-test/... URLs only work while manually executing in n8n.
N8N_ASSIGNMENT_WEBHOOK_URL=
N8N_HUMANIZER_WEBHOOK_URL=

# Optional: if your n8n webhook needs a header token.
N8N_WEBHOOK_AUTH_HEADER=
N8N_WEBHOOK_AUTH_VALUE=

# Optional runtime tuning.
SERVICE_NAME=assignment-humanizer
N8N_WEBHOOK_TIMEOUT_MS=30000
N8N_WEBHOOK_RETRIES=1
MAX_INPUT_CHARS=20000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
